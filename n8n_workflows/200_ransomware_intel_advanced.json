    {
      "id": "e97d6cbb-e9e8-4395-a249-88b96dd2ecff",
      "name": "Advanced TTP + YARA Output",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
      "position": [
        1680,
        350
      ],
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"threat_level\": {\n      \"type\": \"string\"\n    },\n    \"confidence_score\": {\n      \"type\": \"number\",\n      \"description\": \"0-100 attribution confidence\"\n    },\n    \"ttps\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"mitre_id\": {\n            \"type\": \"string\"\n          },\n          \"tactic\": {\n            \"type\": \"string\"\n          },\n          \"technique\": {\n            \"type\": \"string\"\n          },\n          \"description\": {\n            \"type\": \"string\"\n          },\n          \"severity\": {\n            \"type\": \"string\"\n          },\n          \"detection_note\": {\n            \"type\": \"string\"\n          }\n        }\n      }\n    },\n    \"yara_rules\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"group\": {\n            \"type\": \"string\"\n          },\n          \"rule_name\": {\n            \"type\": \"string\"\n          },\n          \"rule_content\": {\n            \"type\": \"string\",\n            \"description\": \"Valid YARA rule syntax\"\n          }\n        }\n      }\n    },\n    \"ioc_summary\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"malicious_domains\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        },\n        \"suspicious_ips\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        },\n        \"file_hashes\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        }\n      }\n    },\n    \"targeting_patterns\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"industries\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        },\n        \"regions\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        },\n        \"victim_profile\": {\n          \"type\": \"string\"\n        },\n        \"selection_criteria\": {\n          \"type\": \"string\"\n        }\n      }\n    },\n    \"operational_intelligence\": {\n      \"type\": \"string\"\n    },\n    \"recommendations\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"action\": {\n            \"type\": \"string\"\n          },\n          \"mitre_addresses\": {\n            \"type\": \"string\"\n          },\n          \"effort\": {\n            \"type\": \"string\"\n          },\n          \"priority\": {\n            \"type\": \"integer\"\n          }\n        }\n      }\n    },\n    \"negotiation_intel\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"typical_demand_range\": {\n          \"type\": \"string\"\n        },\n        \"payment_methods\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        },\n        \"decryptor_reliability\": {\n          \"type\": \"string\"\n        },\n        \"recommendation\": {\n          \"type\": \"string\"\n        }\n      }\n    }\n  }\n}"
      }
    },
    {
      "id": "f9547aeb-998f-4306-af31-a4748b51bbce",
      "name": "Generate YARA Rules File",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        0
      ],
      "parameters": {
        "jsCode": "// Bundle YARA rules into a deployable .yar file\nconst ai = $input.all()[0].json.ai_analysis || {};\nconst rules = ai.yara_rules || [];\nlet yar = '// RANSOMWARE DETECTION RULES\\n// Generated by AI Ransomware Intelligence Platform\\n// Classification: CONFIDENTIAL\\n\\n';\nrules.forEach(r => {\n  yar += `// Group: ${r.group}\\n${r.rule_content}\\n\\n`;\n});\nconst buf = Buffer.from(yar, 'utf-8');\nreturn [{ json: { fileName: `ransomware_detection_${new Date().toISOString().split('T')[0]}.yar`, ruleCount: rules.length },\n  binary: { data: { data: buf.toString('base64'), mimeType: 'text/plain', fileName: 'ransomware_rules.yar' } } }];"
      }
    },
