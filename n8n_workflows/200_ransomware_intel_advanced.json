    },
    {
      "id": "ba3eea16-acea-489b-9268-9ba68fdccda3",
      "name": "Filter & Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        0
      ],
      "parameters": {
        "jsCode": "// Filter by monitored industries + deduplicate victims\nconst victims = $input.all()[0].json || [];\nconst industries = ['Healthcare', 'Manufacturing', 'Financial', 'Education', 'Government'];\nreturn victims\n  .filter(v => industries.some(i => v.activity?.toLowerCase().includes(i.toLowerCase())))\n  .slice(0, 100)\n  .map(v => ({ json: v }));"
      }
    },
    {
      "id": "8a07bfcb-d46d-425f-9d17-23544a22f2d1",
      "name": "Extract IOCs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        0
      ],
      "parameters": {
        "jsCode": "// Extract domains and IPs from victim records for enrichment\nconst items = $input.all();\nconst iocs = [];\nitems.forEach(item => {\n  const v = item.json;\n  if (v.website) iocs.push({ type: 'domain', value: v.website.replace(/https?:\\/\\//, '').split('/')[0], victim: v.post_title });\n  // Add any discovered IPs from profile data\n});\nreturn iocs.slice(0, 10).map(i => ({ json: i })); // Limit to 10 IOCs to respect API limits"
      }
    },
    {
      "id": "bfc80bcb-ebdc-4046-aec2-912a50e1a57e",
      "name": "VirusTotal IOC Lookup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://www.virustotal.com/api/v3/domains/{{$json.value}}",
        "options": {}
      }
    },
    {
      "id": "c2d267db-1acc-4f1f-bd5b-743a5248c0d4",
      "name": "AbuseIPDB Lookup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        120
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://api.abuseipdb.com/api/v2/check?ipAddress={{$json.value}}&maxAgeInDays=90",
        "options": {}
      }
    },
    {
      "id": "d8ef1069-fe23-4ff1-b4a3-492d313cc894",
      "name": "Enrich Victim Data with IOC Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        0
      ],
      "parameters": {
        "jsCode": "// Merge IOC lookup results with victim data\n// Flag high-risk victims based on malicious IOC hits\nconst vtData = $node['VirusTotal IOC Lookup'].json;\nconst malicious = vtData?.data?.attributes?.last_analysis_stats?.malicious || 0;\nconst riskFlag = malicious > 5 ? 'CONFIRMED_MALICIOUS' : malicious > 0 ? 'SUSPICIOUS' : 'CLEAN';\nreturn [{ json: { ...($input.all()[0].json || {}), ioc_risk_flag: riskFlag, vt_malicious_count: malicious } }];"
      }
    },
    {
      "id": "2f585992-ca3d-4d90-b9f0-6a442d53099a",
      "name": "Build Historical Baseline",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        0
      ],
      "parameters": {
        "jsCode": "// Compare current 30d window against prior 30d window\n// Uses n8n variables or external KV store to persist prior counts\n// For demo: generates synthetic baseline comparison\nconst currentVictims = $input.all().length;\nconst priorBaseline = $vars.PRIOR_VICTIM_COUNT || Math.floor(currentVictims * 0.75);\nconst delta = ((currentVictims - priorBaseline) / priorBaseline * 100).toFixed(1);\nconst trend = currentVictims > priorBaseline ? 'INCREASING' : currentVictims < priorBaseline ? 'DECREASING' : 'STABLE';\nreturn [{ json: { current: currentVictims, prior: priorBaseline, delta_pct: delta, trend } }];"
      }
    },
    {
